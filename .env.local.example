# ── Cadence environment variables ──────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# Only NEXT_PUBLIC_* vars reach the browser. Everything else is server-only.

# Claude API (server only)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# Supabase — service role (server only; full DB access; used by lib/seed.ts and admin routes)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# Google OAuth (configured in the Supabase Auth dashboard; client secret is server-only)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# Secures the OPTIONAL Vercel-cron HTTP endpoint /api/cron/missing-hours (Pro tier only).
# The primary reminder path is Supabase pg_cron and needs no secret.
CRON_SECRET=generate-a-long-random-string
